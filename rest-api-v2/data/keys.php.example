/**
 * API キー設定の例。
 *
 * 実際のキーは bin/make-key.php で生成すること:
 *   php rest-api-v2/bin/make-key.php --label my-editor --scope write
 *
 * このファイルを keys.php にコピーして使う場合も、key_sha256 には
 * 「生キーの SHA-256 ハッシュ」を入れる（生キーそのものは保存しない）。
 */
return [
